# ============================================================
# متغيرات البيئة — مواعيدك
# ============================================================
# انسخ هذا الملف إلى .env وضع القيم الحقيقية
# تحذير: لا تضع أسراراً حقيقية في هذا الملف أو في git
# ============================================================

# ----- مطلوب الآن -----

# PostgreSQL connection string
DATABASE_URL=postgres://user:password@host:5432/dbname

# Express session secret (عشوائي وطويل)
SESSION_SECRET=change_me_to_a_long_random_string

# ----- API Routing -----

# Production Express API base URL used by the frontend when the API is deployed separately.
# Leave empty only when the frontend and API are served from the same origin.
# Example: VITE_API_BASE_URL=https://mawaeedak-api-server.vercel.app
# VITE_API_BASE_URL=

# ----- CORS Configuration -----
# Comma-separated list of allowed origins for production
# Example: ALLOWED_ORIGINS=https://mawaeedak.vercel.app,https://www.mawaeedak.com
# Leave empty in development (localhost allowed automatically)
# In production, CORS will reject requests from origins not in this list
ALLOWED_ORIGINS=

# ----- Supabase (مفعّل) -----

# Public Supabase URL (آمن للواجهة)
# VITE_SUPABASE_URL=https://your-project.supabase.co

# Public Anon Key (آمن للواجهة — لا يصل لبيانات محمية بدون RLS)
# VITE_SUPABASE_ANON_KEY=eyJ...

# ----- Supabase (الخادم — للتحقق من توكن المالك في requireAdmin) -----
# يستخدمها api-server للتحقق من JWT المرسل من الواجهة عبر ${SUPABASE_URL}/auth/v1/user
# نفس قيم VITE_ أعلاه لكن بدون بادئة VITE_ (متاحة للخادم فقط)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=eyJ...

# تحذير أمني صريح:
# لا تضع SUPABASE_SERVICE_ROLE_KEY في الواجهة أبداً
# service_role key تعطي صلاحيات كاملة — استخدمها في الخادم فقط
# SUPABASE_SERVICE_ROLE_KEY=eyJ...  <-- خادم فقط، لا VITE_

# ----- Data Source Mode -----
#
# يتحكم في مصدر البيانات الرئيسي للواجهة.
# القيم المقبولة:
#   api              — PostgreSQL/Express (الافتراضي الآمن)
#   supabase_shadow  — API يُعرض للمستخدم + Supabase للمقارنة فقط
#   supabase         — Supabase مصدر الحقيقة (الإنتاج)
#
# للإنتاج مع Supabase:
#   VITE_DATA_SOURCE_MODE=supabase
#
# أي قيمة غير صحيحة أو غياب المتغير → يُعيد api تلقائياً
#
# VITE_DATA_SOURCE_MODE=api

# ----- Firebase (مستقبلي — اختياري للـ Push) -----

# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_VAPID_KEY=

# ----- تطوير -----

# PORT يُوفَّر تلقائياً من workflow (لا تحتاج تعيينه يدوياً)
# PORT=5173

# ----- أتمتة X (تويتر) — اختياري، النشر الحي مؤجَّل (P2) -----
# عند غيابها: لوحة المالك تعرض "غير متصل" بصدق ولا تزيّف النجاح
# X_CLIENT_ID=
# X_CLIENT_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=
