{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm run build",
  "outputDirectory": "artifacts/mawaeedak/dist/public",
  "rewrites": [
    {
      "source": "/((?!assets/|icons/|manifest.json|favicon.svg|robots.txt|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
