{
  "version": 2,
  "installCommand": "corepack enable && pnpm install --no-frozen-lockfile",
  "buildCommand": "cd artifacts/mawaeedak && pnpm run build",
  "outputDirectory": "artifacts/mawaeedak/dist/public",
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
