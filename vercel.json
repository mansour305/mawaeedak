{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "VITE_DATA_SOURCE_MODE=supabase pnpm run build",
  "outputDirectory": "artifacts/mawaeedak/dist/public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
